<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/automation_widget_background"
    android:orientation="vertical"
    android:padding="9dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/automation_widget_logo_background"
            android:gravity="center"
            android:text="P_"
            android:textColor="#FFD43B"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PIXELPY AUTO"
                android:textColor="#6B6457"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="REPORTE DIARIO"
                android:textColor="#191919"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:background="@drawable/automation_widget_status_pending"
            android:gravity="center"
            android:minWidth="66dp"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:text="PENDIENTE"
            android:textColor="#191919"
            android:textSize="8sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Todavía no se ejecutó"
        android:textColor="#6B6457"
        android:textSize="9sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="7dp"
        android:layout_weight="1"
        android:background="@drawable/automation_widget_artifact_background"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="6dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ÚLTIMO RESULTADO"
            android:textColor="#6B6457"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_artifact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="middle"
            android:maxLines="1"
            android:text="Sin resultado publicado"
            android:textColor="#191919"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="7dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_open"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@drawable/automation_widget_button_secondary"
            android:gravity="center"
            android:text="ABRIR"
            android:textColor="#191919"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="7dp"
            android:layout_height="1dp"
            android:text="" />

        <TextView
            android:id="@+id/widget_run"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@drawable/automation_widget_button_primary"
            android:gravity="center"
            android:text="▶  EJECUTAR"
            android:textColor="#FFD43B"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
